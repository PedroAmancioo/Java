<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="329.0" prefWidth="505.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.lunaltas.demo.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" text="Lista de Usuários" />
    <HBox prefHeight="100.0" prefWidth="200.0">
        <children>
            <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Nome" />
                    <TextField fx:id="inputName">
                        <VBox.margin>
                            <Insets right="5.0" />
                        </VBox.margin>
                    </TextField>
                </children>
            </VBox>
            <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="E-mail" />
                    <TextField fx:id="inputEmail">
                        <VBox.margin>
                            <Insets right="5.0" />
                        </VBox.margin>
                    </TextField>
                </children>
            </VBox>
            <Button onAction="#onHelloButtonClick" text="Atualizar" HBox.hgrow="ALWAYS">
                <HBox.margin>
                    <Insets top="18.0" />
                </HBox.margin>
            </Button>
        </children>
    </HBox>
    <TableView fx:id="tabela" prefHeight="200.0" prefWidth="200.0">
        <columns>
            <TableColumn fx:id="colNome" prefWidth="218.0" text="C1" />
            <TableColumn fx:id="colEmail" prefWidth="244.0" text="C2" />
        </columns>
    </TableView>
</VBox>