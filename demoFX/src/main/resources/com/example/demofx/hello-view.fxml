<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demofx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <DatePicker>
      <VBox.margin>
         <Insets bottom="50.0" />
      </VBox.margin>
   </DatePicker>
   <ChoiceBox prefWidth="150.0" />
   <Circle fill="DODGERBLUE" onMouseClicked="#onHelloButtonClick" radius="100.0" stroke="BLACK" strokeType="INSIDE" />

    <Label fx:id="welcomeText" />
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
          <Button onAction="#onHelloButtonClick" prefHeight="190.0" prefWidth="192.0" style="-fx-background-radius: 100em; -fx-min-width: 100px; -fx-background-color: ff0000;" text="Aperte aqui!" />
      </children>
   </HBox>
</VBox>
